function initModules() {
  const grid = document.getElementById('moduleGrid');
  grid.innerHTML = '';
  MODULES.forEach(m => {
    const el = document.createElement('div');
    el.className = `module-item ${m.on?'on':''} ${m.crit?'crit':''}`;
    el.id = 'mod-' + m.id;
    el.innerHTML = `
      <div class="mod-header">
        <div class="mod-icon">${m.icon}</div>
        <div class="toggle-sw"></div>
      </div>
      <div class="mod-name">${m.name}</div>
      <div class="mod-desc">${m.desc}</div>
    `;
    el.onclick = () => toggleMod(m.id);
    grid.appendChild(el);
  });
  updateModBadge();
}

function toggleMod(id) {
  const m = MODULES.find(x => x.id === id);
  const el = document.getElementById('mod-' + id);
  m.on = !m.on;
  el.className = `module-item ${m.on?'on':''} ${m.crit?'crit':''}`;
  updateModBadge();
  notify(m.on ? `Module enabled: ${m.name}` : `Module disabled: ${m.name}`, m.on ? 'ok' : 'warn');
}

function enableAll()  { MODULES.forEach(m => { m.on = true;  document.getElementById('mod-'+m.id).className = `module-item on ${m.crit?'crit':''}`; }); updateModBadge(); notify('All modules enabled.','ok'); }
function disableAll() { MODULES.forEach(m => { m.on = false; document.getElementById('mod-'+m.id).className = `module-item ${m.crit?'crit':''}`; }); updateModBadge(); notify('All modules disabled.','warn'); }

function updateModBadge() {
  const n = MODULES.filter(m => m.on).length;
