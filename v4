  font-size: 13px;
  color: var(--t1);
  margin-bottom: 8px;
  display: flex; align-items: center; gap: 6px;
}

.skill-bar {
  height: 4px;
  background: var(--surface3);
  border-radius: 2px;
  overflow: hidden;
  margin-bottom: 4px;
}

.skill-fill {
  height: 100%;
  border-radius: 2px;
  background: linear-gradient(90deg, var(--violet), var(--cyan));
