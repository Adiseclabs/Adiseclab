.tool-pill {
  display: inline-block;
  font-family: var(--mono);
  font-size: 11px;
  padding: 4px 11px;
  border-radius: 5px;
  background: var(--surface2);
  border: 1px solid var(--border2);
  color: var(--t2);
  margin: 3px;
  transition: all 0.15s;
}

.tool-pill:hover { color: var(--cyan); border-color: rgba(0,212,255,.25); background: var(--cyan-dim); }

/* ════════════════════════════════════════
   NOTIFICATIONS
════════════════════════════════════════ */
#notifs {
  position: fixed;
  bottom: 20px; right: 20px;
  display: flex; flex-direction: column; gap: 8px;
  z-index: 9999;
}

.notif-pill {
  background: var(--surface2);
  border: 1px solid var(--border2);
  border-left: 3px solid var(--cyan);
  border-radius: var(--radius);
  padding: 11px 15px;
  font-size: 12px;
  color: var(--t1);
  max-width: 300px;
  backdrop-filter: blur(12px);
  animation: npIn 0.25s ease;
  box-shadow: 0 8px 24px rgba(0,0,0,0.4);
}

.notif-pill.ok     { border-left-color: var(--green); }
.notif-pill.warn   { border-left-color: var(--yellow); }
.notif-pill.danger { border-left-color: var(--red); }

@keyframes npIn  { from{transform:translateX(20px);opacity:0} to{transform:translateX(0);opacity:1} }
@keyframes npOut { from{transform:translateX(0);opacity:1}    to{transform:translateX(20px);opacity:0} }

/* ════════════════════════════════════════
   RESPONSIVE / MOBILE NAV
