<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AdiSecLab — Elite Bug Bounty Intelligence Platform</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;700&family=Syne:wght@400;600;700;800&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════
   ADISECLAB v4.0 — DESIGN SYSTEM
   Developed by Aditya Bhosale
═══════════════════════════════════════════════════ */

:root {
  /* Core palette */
  --ink:        #050810;
  --surface:    #080d1a;
  --surface2:   #0c1326;
  --surface3:   #111d35;
  --border:     rgba(255,255,255,0.06);
  --border2:    rgba(255,255,255,0.10);

  /* Accent system */
  --cyan:       #00d4ff;
  --cyan-dim:   rgba(0,212,255,0.12);
  --cyan-glow:  0 0 24px rgba(0,212,255,0.25);
  --red:        #ff4560;
  --red-dim:    rgba(255,69,96,0.12);
  --orange:     #ff7b00;
  --yellow:     #ffd60a;
  --green:      #00e5a0;
  --green-dim:  rgba(0,229,160,0.10);
  --violet:     #7c6aff;
  --violet-dim: rgba(124,106,255,0.12);

  /* Text */
  --t1: #f0f4ff;
  --t2: #8fa3c0;
  --t3: #4d6480;

  /* Misc */
  --radius:  10px;
  --radius2: 6px;
  --mono:    'JetBrains Mono', monospace;
  --display: 'Syne', sans-serif;
  --body:    'Inter', sans-serif;
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

html { scroll-behavior: smooth; }

body {
  background: var(--ink);
  color: var(--t1);
  font-family: var(--body);
  min-height: 100vh;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
}

/* ── NOISE TEXTURE ── */
body::before {
  content:'';
  position:fixed; inset:0; z-index:0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
  pointer-events:none;
  opacity:.4;
}

/* ── AMBIENT LIGHT ── */
.ambient {
  position:fixed; inset:0; z-index:0; pointer-events:none;
  background:
    radial-gradient(ellipse 800px 500px at 20% -10%, rgba(0,212,255,0.04) 0%, transparent 70%),
    radial-gradient(ellipse 600px 400px at 80% 110%, rgba(124,106,255,0.04) 0%, transparent 70%),
    radial-gradient(ellipse 400px 300px at 60% 40%, rgba(255,69,96,0.02) 0%, transparent 60%);
}

.wrapper { position:relative; z-index:1; }

/* ════════════════════════════════════════
   SIDEBAR NAV
════════════════════════════════════════ */
.sidebar {
  position: fixed;
  left: 0; top: 0; bottom: 0;
  width: 220px;
  background: var(--surface);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  z-index: 100;
  transition: transform 0.3s ease;
}

.sidebar-logo {
  padding: 24px 20px 20px;
  border-bottom: 1px solid var(--border);
}

.logo-mark {
  display: flex; align-items: center; gap: 10px;
  margin-bottom: 6px;
}

.logo-hex {
  width: 36px; height: 36px;
  background: var(--cyan-dim);
  border: 1.5px solid var(--cyan);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--display);
  font-weight: 800;
  font-size: 16px;
  color: var(--cyan);
  box-shadow: var(--cyan-glow);
  position: relative;
  flex-shrink: 0;
}

.logo-hex::after {
  content:'';
  position:absolute; inset:-4px;
  border-radius:11px;
  border: 1px solid rgba(0,212,255,0.15);
}

.logo-wordmark {
  font-family: var(--display);
  font-weight: 800;
  font-size: 17px;
  color: var(--t1);
  letter-spacing: 0.5px;
}

.logo-tagline {
  font-family: var(--mono);
  font-size: 9px;
  color: var(--t3);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-top: 2px;
}

.sidebar-ver {
  display: inline-block;
  font-family: var(--mono);
  font-size: 9px;
  padding: 2px 7px;
  border-radius: 10px;
  background: var(--cyan-dim);
  color: var(--cyan);
  border: 1px solid rgba(0,212,255,0.2);
  margin-top: 8px;
}

.nav-section {
  padding: 12px 12px 4px;
  font-family: var(--mono);
  font-size: 9px;
  color: var(--t3);
  letter-spacing: 2px;
  text-transform: uppercase;
}

.nav-item {
  display: flex; align-items: center; gap: 10px;
  padding: 9px 16px;
  margin: 1px 8px;
  border-radius: var(--radius2);
  cursor: pointer;
  transition: all 0.18s;
  font-size: 13px;
  font-weight: 500;
  color: var(--t2);
  border: 1px solid transparent;
  position: relative;
  white-space: nowrap;
}

.nav-item:hover {
  background: var(--surface2);
  color: var(--t1);
}

.nav-item.active {
  background: var(--cyan-dim);
  color: var(--cyan);
  border-color: rgba(0,212,255,0.15);
}

.nav-item.active::before {
  content:'';
  position:absolute;
  left:-8px; top:50%;
  transform:translateY(-50%);
  width:3px; height:20px;
  background:var(--cyan);
  border-radius:0 2px 2px 0;
  box-shadow:0 0 8px var(--cyan);
}

.nav-icon { font-size: 15px; flex-shrink:0; width:18px; text-align:center; }

.nav-badge {
  margin-left: auto;
  font-family: var(--mono);
  font-size: 9px;
  padding: 1px 6px;
  border-radius: 8px;
  background: var(--red-dim);
  color: var(--red);
  border: 1px solid rgba(255,69,96,0.2);
}

.sidebar-bottom {
  margin-top: auto;
  padding: 16px 12px;
  border-top: 1px solid var(--border);
}

.dev-card {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 12px;
  background: var(--surface2);
  border-radius: var(--radius);
  border: 1px solid var(--border);
  cursor: pointer;
  transition: all 0.2s;
  text-decoration: none;
}

.dev-card:hover {
  border-color: var(--border2);
  background: var(--surface3);
}

.dev-avatar {
  width: 32px; height: 32px;
  border-radius: 8px;
  background: linear-gradient(135deg, var(--cyan), var(--violet));
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 13px; color: #000;
  font-family: var(--display);
  flex-shrink: 0;
}

.dev-info { min-width: 0; }
.dev-name { font-size: 12px; font-weight: 600; color: var(--t1); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.dev-role { font-family: var(--mono); font-size: 9px; color: var(--t3); letter-spacing:1px; }

/* ════════════════════════════════════════
   MAIN CONTENT
════════════════════════════════════════ */
.main-content {
  margin-left: 220px;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ── TOPBAR ── */
.topbar {
  height: 60px;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 28px;
  background: rgba(8,13,26,0.8);
  border-bottom: 1px solid var(--border);
  backdrop-filter: blur(12px);
  position: sticky; top: 0; z-index: 50;
}

.topbar-left {
  display: flex; align-items: center; gap: 8px;
  font-size: 13px; color: var(--t2);
}

.topbar-left strong { color: var(--t1); font-weight:600; }
.breadcrumb-sep { color: var(--t3); }

.topbar-right { display: flex; align-items: center; gap: 12px; }

.sys-badge {
  display: flex; align-items: center; gap: 6px;
  font-family: var(--mono);
  font-size: 10px;
  color: var(--green);
  padding: 5px 12px;
  border-radius: 20px;
  background: var(--green-dim);
  border: 1px solid rgba(0,229,160,0.2);
}

.sys-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--green);
  box-shadow: 0 0 6px var(--green);
  animation: sysPulse 2s ease-in-out infinite;
}

@keyframes sysPulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.5;transform:scale(0.8)} }

.time-display {
  font-family: var(--mono);
  font-size: 12px;
  color: var(--t3);
  letter-spacing: 1px;
}

/* ════════════════════════════════════════
   PAGE CONTENT AREAS
════════════════════════════════════════ */
.page { display:none; padding: 28px; }
.page.active { display:block; }

/* ── PAGE HEADER ── */
.page-header {
  margin-bottom: 28px;
}

.page-title {
  font-family: var(--display);
  font-size: 26px;
  font-weight: 800;
  color: var(--t1);
  line-height: 1.1;
  margin-bottom: 6px;
}

.page-sub {
  font-size: 13px;
  color: var(--t2);
  line-height: 1.5;
}

/* ── CARDS ── */
.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  transition: border-color 0.2s;
}

.card:hover { border-color: var(--border2); }

.card-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 18px;
  border-bottom: 1px solid var(--border);
  background: rgba(255,255,255,0.015);
}

.card-title {
  display: flex; align-items: center; gap: 8px;
  font-size: 12px;
  font-weight: 600;
  color: var(--t2);
  font-family: var(--mono);
  letter-spacing: 1px;
  text-transform: uppercase;
}

.card-icon { font-size: 14px; }
.card-body { padding: 18px; }

/* ── CHIP / BADGE ── */
.chip {
  display: inline-flex; align-items: center; gap: 4px;
  font-family: var(--mono);
  font-size: 10px;
  padding: 3px 9px;
  border-radius: 20px;
  border: 1px solid;
  letter-spacing: 0.5px;
  font-weight: 500;
}

.chip-cyan  { color:var(--cyan);   background:var(--cyan-dim);   border-color:rgba(0,212,255,0.2); }
.chip-red   { color:var(--red);    background:var(--red-dim);    border-color:rgba(255,69,96,0.2); }
.chip-orange{ color:var(--orange); background:rgba(255,123,0,.1);border-color:rgba(255,123,0,.25); }
.chip-yellow{ color:var(--yellow); background:rgba(255,214,10,.08);border-color:rgba(255,214,10,.2); }
.chip-green { color:var(--green);  background:var(--green-dim);  border-color:rgba(0,229,160,0.2); }
.chip-violet{ color:var(--violet); background:var(--violet-dim); border-color:rgba(124,106,255,.2); }

/* ── GRID SYSTEMS ── */
.g2 { display:grid; grid-template-columns:1fr 1fr; gap:16px; }
.g3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:16px; }
.g4 { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; }
.g5 { display:grid; grid-template-columns:repeat(5,1fr); gap:12px; }

@media(max-width:1200px){ .g4{grid-template-columns:repeat(2,1fr);} .g5{grid-template-columns:repeat(3,1fr);} }
@media(max-width:960px){ .g3,.g2{grid-template-columns:1fr;} }

/* ════════════════════════════════════════
   TARGET / SCAN BAR
════════════════════════════════════════ */
.scan-bar {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px 22px;
  margin-bottom: 20px;
  position: relative;
}

.scan-bar::before {
  content:'';
  position:absolute; top:0; left:0; right:0; height:2px;
  background:linear-gradient(90deg, transparent, var(--cyan), var(--violet), transparent);
  border-radius: var(--radius) var(--radius) 0 0;
  opacity: 0.6;
}

.scan-bar-label {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--t3);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 10px;
}

.scan-input-row {
  display: flex; gap: 10px; align-items: center; flex-wrap: wrap;
}

.target-field {
  flex: 1; min-width: 280px;
  background: var(--surface2);
  border: 1px solid var(--border2);
  border-radius: var(--radius2);
  padding: 11px 16px;
  font-family: var(--mono);
  font-size: 13px;
  color: var(--cyan);
  outline: none;
  transition: all 0.2s;
  caret-color: var(--cyan);
}

.target-field:focus {
  border-color: rgba(0,212,255,0.4);
  background: var(--surface3);
  box-shadow: 0 0 0 3px rgba(0,212,255,0.06);
}

.target-field::placeholder { color: var(--t3); font-family: var(--mono); }

/* ── BUTTONS ── */
.btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 7px;
  padding: 10px 20px;
  border-radius: var(--radius2);
  font-family: var(--body);
  font-size: 13px;
  font-weight: 600;
  cursor: pointer;
  border: 1px solid transparent;
  transition: all 0.18s;
  white-space: nowrap;
  letter-spacing: 0.2px;
}

.btn-primary {
  background: var(--cyan);
  color: #050810;
  border-color: var(--cyan);
  box-shadow: 0 4px 16px rgba(0,212,255,0.2);
}

.btn-primary:hover {
  background: #33ddff;
  box-shadow: 0 4px 24px rgba(0,212,255,0.35);
  transform: translateY(-1px);
}

.btn-primary:active { transform: translateY(0); box-shadow: none; }

.btn-primary.scanning {
  background: var(--red);
  border-color: var(--red);
  color: #fff;
  box-shadow: 0 4px 16px rgba(255,69,96,0.3);
  animation: scanBtn 2s ease-in-out infinite;
}

@keyframes scanBtn {
  0%,100%{box-shadow:0 4px 16px rgba(255,69,96,0.3)}
  50%{box-shadow:0 4px 28px rgba(255,69,96,0.5)}
}

.btn-ghost {
  background: transparent;
  color: var(--t2);
  border-color: var(--border2);
}

.btn-ghost:hover {
  background: var(--surface2);
  color: var(--t1);
  border-color: rgba(255,255,255,0.15);
}

.btn-danger {
  background: var(--red-dim);
  color: var(--red);
  border-color: rgba(255,69,96,0.25);
}

.btn-danger:hover { background: rgba(255,69,96,0.18); }

.btn-sm { padding: 6px 14px; font-size: 12px; }
.btn-xs { padding: 4px 10px; font-size: 11px; }

/* ── MODE PILLS ── */
.mode-row {
  display: flex; gap: 6px; flex-wrap: wrap;
  margin-top: 14px;
}

.mode-pill {
  display: flex; align-items: center; gap: 5px;
  padding: 5px 13px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 500;
  cursor: pointer;
  border: 1px solid var(--border2);
  color: var(--t2);
  background: transparent;
  transition: all 0.18s;
}

.mode-pill:hover { color: var(--t1); border-color: rgba(255,255,255,0.2); }

.mode-pill.active { font-weight: 600; }
.mode-pill.m-recon.active   { background:var(--cyan-dim);   color:var(--cyan);   border-color:rgba(0,212,255,0.3); }
.mode-pill.m-vuln.active    { background:var(--red-dim);    color:var(--red);    border-color:rgba(255,69,96,0.3); }
.mode-pill.m-fuzz.active    { background:rgba(255,123,0,.1);color:var(--orange); border-color:rgba(255,123,0,.3); }
.mode-pill.m-osint.active   { background:var(--violet-dim); color:var(--violet); border-color:rgba(124,106,255,.3); }
.mode-pill.m-api.active     { background:rgba(255,214,10,.08);color:var(--yellow);border-color:rgba(255,214,10,.25); }
.mode-pill.m-god.active     { background:linear-gradient(90deg,rgba(0,212,255,.1),rgba(124,106,255,.1)); color:var(--t1); border-color:rgba(0,212,255,.3); }

/* ════════════════════════════════════════
   STAT CARDS
════════════════════════════════════════ */
.stat-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 12px;
  margin-bottom: 20px;
}

@media(max-width:1000px){ .stat-grid{grid-template-columns:repeat(3,1fr);} }

.stat-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px 18px;
  position: relative;
  overflow: hidden;
  transition: all 0.2s;
}

.stat-card:hover { border-color: var(--border2); transform: translateY(-2px); }

.stat-card::after {
  content:'';
  position:absolute; bottom:0; left:0; right:0; height:2px;
}

.stat-card.sc-crit::after { background:linear-gradient(90deg,transparent,var(--red),transparent); }
.stat-card.sc-high::after { background:linear-gradient(90deg,transparent,var(--orange),transparent); }
.stat-card.sc-med::after  { background:linear-gradient(90deg,transparent,var(--yellow),transparent); }
.stat-card.sc-low::after  { background:linear-gradient(90deg,transparent,var(--green),transparent); }
.stat-card.sc-info::after { background:linear-gradient(90deg,transparent,var(--cyan),transparent); }

.stat-num {
  font-family: var(--display);
  font-size: 36px;
  font-weight: 800;
  line-height: 1;
  margin-bottom: 6px;
}

.sc-crit .stat-num { color:var(--red); }
.sc-high .stat-num { color:var(--orange); }
.sc-med  .stat-num { color:var(--yellow); }
.sc-low  .stat-num { color:var(--green); }
.sc-info .stat-num { color:var(--cyan); }

.stat-label {
  font-size: 11px;
  font-weight: 500;
  color: var(--t3);
  text-transform: uppercase;
  letter-spacing: 1px;
}

.stat-icon {
  position: absolute; top: 14px; right: 14px;
  font-size: 22px; opacity: 0.15;
}

/* ════════════════════════════════════════
   PROGRESS
════════════════════════════════════════ */
.progress-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 20px 22px;
  margin-bottom: 20px;
  display: none;
}

.progress-card.visible { display: block; }

.progress-meta {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 12px;
}

.progress-status {
  display: flex; align-items: center; gap: 10px;
}

.progress-label {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--t2);
  letter-spacing: 1.5px;
  text-transform: uppercase;
}

.spin {
  width: 14px; height: 14px;
  border: 2px solid var(--border2);
  border-top-color: var(--cyan);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.progress-pct {
  font-family: var(--display);
  font-size: 24px;
  font-weight: 800;
  color: var(--cyan);
}

.progress-track {
  height: 6px;
  background: var(--surface3);
  border-radius: 3px;
  overflow: hidden;
  margin-bottom: 14px;
}

.progress-fill {
  height: 100%;
  border-radius: 3px;
  background: linear-gradient(90deg, var(--violet), var(--cyan));
  width: 0%;
  transition: width 0.4s ease;
  position: relative;
}

.progress-fill::after {
  content:'';
  position:absolute; right:0; top:0; bottom:0; width:20px;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5));
  border-radius: 3px;
  animation: shimmer 1.2s ease-in-out infinite;
}

@keyframes shimmer { 0%{opacity:0} 50%{opacity:1} 100%{opacity:0} }

.step-row {
  display: flex; gap: 5px; flex-wrap: wrap;
}

.step-tag {
  font-family: var(--mono);
  font-size: 9px;
  padding: 3px 8px;
  border-radius: 3px;
  border: 1px solid var(--border);
  color: var(--t3);
  background: transparent;
  transition: all 0.3s;
  letter-spacing: 1px;
}

.step-tag.done { border-color: rgba(0,229,160,0.3); color: var(--green); background: var(--green-dim); }
.step-tag.running { border-color: rgba(0,212,255,0.3); color: var(--cyan); background: var(--cyan-dim); animation: stepBlink 0.9s ease-in-out infinite; }

@keyframes stepBlink { 0%,100%{opacity:1} 50%{opacity:.5} }

/* ════════════════════════════════════════
   TERMINAL
════════════════════════════════════════ */
.terminal-wrap {
  background: #030609;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  margin-bottom: 20px;
}

.term-titlebar {
  display: flex; align-items: center; gap: 6px;
  padding: 10px 14px;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
}

.tdot { width: 10px; height: 10px; border-radius: 50%; }
.tdot-r { background: #ff5f57; }
.tdot-y { background: #febc2e; }
.tdot-g { background: #28c840; }

.term-title {
  font-family: var(--mono);
  font-size: 11px;
  color: var(--t3);
  margin-left: 8px;
  flex: 1;
}

.term-acts { display: flex; gap: 6px; }

.term-btn {
