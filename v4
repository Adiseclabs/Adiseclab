    if (logI < LOG_SCRIPT.length && Math.random() > 0.35) {
      const e = LOG_SCRIPT[logI](t);
      addLog(e.type, e.msg);
      logI++;
    }

    // Findings drip
    if (scanProgress > 35 && findIdx < FAKE_FINDINGS.length && Math.random() > 0.55) {
      findings.push(FAKE_FINDINGS[findIdx++]);
      renderFindings();
      updateStats();
    }

    if (scanProgress >= 100) {
      while (findIdx < FAKE_FINDINGS.length) { findings.push(FAKE_FINDINGS[findIdx++]); }
      SCAN_STEPS.forEach(s => {
        const el = document.getElementById('st-'+s);
        if (el) { el.classList.add('done'); el.classList.remove('running'); }
      });
      renderFindings(); updateStats();
      stopScan(true);
    }

  }, 280);
}

function stopScan(complete = false) {
  scanning = false;
  if (scanTimer) { clearInterval(scanTimer); scanTimer = null; }
  document.getElementById('scanBtn').classList.remove('scanning');
  document.getElementById('scanBtnIcon').textContent = '▶';
  document.getElementById('scanBtnTxt').textContent = 'Launch Scan';
  document.getElementById('spinEl').style.display = complete ? 'none' : '';
  document.getElementById('progLabel').textContent = complete ? 'SCAN COMPLETE' : 'SCAN STOPPED';

  if (complete) {
    document.getElementById('progFill').style.width = '100%';
    document.getElementById('progPct').textContent = '100%';
    document.getElementById('exportBtnTop').style.display = '';
    if (findings.length) document.getElementById('exportBar').style.display = 'flex';
    notify(`Scan complete — ${findings.length} vulnerabilities found!`, 'ok');
    addLog('ok', `<span class="g">Scan complete.</span> ${findings.length} findings. View Findings tab for full report.`);
  } else {
    notify('Scan stopped.', 'warn');
    addLog('warn', 'Scan stopped by user.');
  }
}

function clearAll() {
  if (scanning) stopScan();
  document.getElementById('targetInput').value = '';
  clearTerm();
  findings = [];
  ['sC','sH','sM','sL','sI'].forEach(id => document.getElementById(id).textContent = '0');
  document.getElementById('findingsArea').innerHTML = '<div class="empty-findings"><div class="eicon">🔍</div><p>No findings yet — launch a scan to populate this report.</p></div>';
  document.getElementById('findChip').textContent = '0 Findings';
  document.getElementById('nbFinds').style.display = 'none';
  document.getElementById('progressCard').classList.remove('visible');
  document.getElementById('exportBtnTop').style.display = 'none';
  document.getElementById('exportBar').style.display = 'none';
  addLog('sys', 'Session cleared. Ready for new target.');
}

function renderFindings() {
  if (!findings.length) return;
  const sev = {critical:0,high:1,medium:2,low:3,info:4};
  const sorted = [...findings].sort((a,b) => sev[a.sev]-sev[b.sev]);

  document.getElementById('findChip').textContent = findings.length + ' Findings';
  const nb = document.getElementById('nbFinds');
  nb.textContent = findings.length;
  nb.style.display = '';

  document.getElementById('findingsArea').innerHTML = `
    <div style="overflow-x:auto;">
    <table class="findings-table">
      <thead><tr>
        <th style="width:110px">Severity</th>
        <th>Vulnerability</th>
        <th style="width:120px">Tool</th>
      </tr></thead>
      <tbody>
        ${sorted.map(f => `
          <tr>
            <td><span class="sev-badge sb-${f.sev}">${f.sev.toUpperCase()}</span></td>
            <td>
              <div class="finding-name">${f.name}</div>
              <div class="finding-url">${f.url}</div>
              <div class="finding-desc">${f.desc}</div>
            </td>
            <td style="font-family:var(--mono);font-size:11px;color:var(--violet)">${f.tool}</td>
          </tr>`).join('')}
      </tbody>
    </table>
    </div>
  `;
}

function updateStats() {
  const c = {critical:0,high:0,medium:0,low:0,info:0};
  findings.forEach(f => c[f.sev]++);
  document.getElementById('sC').textContent = c.critical;
  document.getElementById('sH').textContent = c.high;
  document.getElementById('sM').textContent = c.medium;
  document.getElementById('sL').textContent = c.low;
  document.getElementById('sI').textContent = c.info;
}

// ── TERMINAL ──
function ts() {
  const n = new Date();
  return [n.getHours(),n.getMinutes(),n.getSeconds()].map(x=>String(x).padStart(2,'0')).join(':');
}

function addLog(type, msg) {
  const body = document.getElementById('termBody');
  const tagMap = {sys:'tt-sys SYS',info:'tt-info INFO',ok:'tt-ok  OK ',warn:'tt-warn WARN',crit:'tt-crit CRIT'};
  const [cls, label] = (tagMap[type]||'tt-info INFO').split(' ');
  const line = document.createElement('div');
  line.className = 'tline';
  line.innerHTML = `<span class="tts">${ts()}</span><span class="ttag ${cls}">${label.trim()}</span><span class="tmsg">${msg}</span>`;
  body.appendChild(line);
  scrollTerm();
}

function clearTerm() {
  document.getElementById('termBody').innerHTML = '';
  addLog('sys', '<span class="v">AdiSecLab</span> — terminal cleared. Ready.');
}

function scrollTerm() {
  const b = document.getElementById('termBody');
  b.scrollTop = b.scrollHeight;
}

// ── CONFIG ──
function saveConfig() {
  document.getElementById('cs-threads').textContent = document.getElementById('cThreads').value;
  document.getElementById('cs-timeout').textContent = document.getElementById('cTimeout').value + 's';
  document.getElementById('cs-rate').textContent = document.getElementById('cRate').value + ' req/s';
  document.getElementById('cs-depth').textContent = document.getElementById('cDepth').value;
  document.getElementById('cs-sev').textContent = document.getElementById('cSev').value;
  document.getElementById('cs-wordlist').textContent = document.getElementById('cWordlist').value;
  const proxy = document.getElementById('cProxy').value;
  document.getElementById('cs-proxy').textContent = proxy || 'None';
  notify('Configuration saved.', 'ok');
}

function resetConfig() {
  document.getElementById('cThreads').value = '50';
  document.getElementById('cTimeout').value = '10';
  document.getElementById('cRate').value = '150';
  document.getElementById('cDepth').value = '3';
  document.getElementById('cProxy').value = '';
  saveConfig();
  notify('Configuration reset to defaults.', '');
}

// ── EXPORT ──
function exportJSON() {
  const target = document.getElementById('targetInput').value || 'unknown';
  const c = {critical:0,high:0,medium:0,low:0,info:0};
  findings.forEach(f => c[f.sev]++);
  const report = {
    tool:'AdiSecLab v4.0.0', developer:'Aditya Bhosale',
    email:'adityabhosale212223@gmail.com',
    linkedin:'https://www.linkedin.com/in/bhsoaleaditya/',
    target, timestamp: new Date().toISOString(),
    scan_mode: currentMode, stats: {...c, total: findings.length}, findings
  };
  const blob = new Blob([JSON.stringify(report,null,2)],{type:'application/json'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `AdiSecLab_${target.replace(/[^a-z0-9]/gi,'_')}_${Date.now()}.json`;
  a.click();
  notify('JSON report exported.', 'ok');
}

function exportCSV() {
  const rows = [['Severity','Vulnerability','URL','Tool','Description']];
  findings.forEach(f => rows.push([f.sev,f.name,f.url,f.tool,`"${f.desc}"`]));
  const blob = new Blob([rows.map(r=>r.join(',')).join('\n')],{type:'text/csv'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = `AdiSecLab_${Date.now()}.csv`;
  a.click();
  notify('CSV exported.', 'ok');
}

function copyFindings() {
  const text = findings.map(f=>`[${f.sev.toUpperCase()}] ${f.name} — ${f.url} (${f.tool})\n${f.desc}`).join('\n\n');
  navigator.clipboard.writeText(text).then(() => notify('Findings copied to clipboard.', 'ok'));
}

// ── NOTIFICATIONS ──
function notify(msg, type='') {
  const area = document.getElementById('notifs');
  const el = document.createElement('div');
  el.className = 'notif-pill' + (type ? ' '+type : '');
  el.textContent = msg;
  area.appendChild(el);
  setTimeout(() => {
    el.style.animation = 'npOut 0.25s ease forwards';
    setTimeout(() => el.remove(), 280);
  }, 3200);
}

// Enter key
document.getElementById('targetInput').addEventListener('keydown', e => {
  if (e.key === 'Enter') toggleScan();
});

// Boot
init();
notify('AdiSecLab v4.0.0 loaded — Developed by Aditya Bhosale.', 'ok');
</script>
