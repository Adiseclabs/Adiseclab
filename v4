}

.cfg-select option { background: #0c1326; }

.info-table { width: 100%; border-collapse: collapse; }
.info-table tr { border-bottom: 1px solid var(--border); }
.info-table tr:last-child { border-bottom: none; }
.info-table td { padding: 10px 14px; font-size: 12px; }
.info-table td:first-child { font-family: var(--mono); color: var(--t3); font-size: 11px; letter-spacing: 1px; width: 45%; }
.info-table td:last-child { color: var(--t1); }

/* ════════════════════════════════════════
   ABOUT SECTION
════════════════════════════════════════ */
.about-hero {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 40px 36px;
  margin-bottom: 20px;
  position: relative;
  overflow: hidden;
}

.about-hero::before {
  content:'';
  position:absolute; top:0; left:0; right:0; height:3px;
  background: linear-gradient(90deg, var(--cyan), var(--violet), var(--red), var(--cyan));
  background-size: 200% 100%;
  animation: gradientFlow 4s linear infinite;
}

@keyframes gradientFlow { 0%{background-position:0% 0%} 100%{background-position:200% 0%} }

.about-hero::after {
  content:'';
  position:absolute; bottom:-80px; right:-80px;
  width:300px; height:300px;
  border-radius:50%;
  background: radial-gradient(circle, rgba(0,212,255,.04) 0%, transparent 70%);
  pointer-events:none;
}

.about-layout {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 36px;
  align-items: center;
  position: relative; z-index:1;
}

.about-avatar-wrap {
  display: flex; flex-direction: column; align-items: center; gap: 14px;
}

.about-avatar {
  width: 110px; height: 110px;
  border-radius: 50%;
  background: linear-gradient(135deg, #001a2e, #001525);
  border: 2px solid rgba(0,212,255,0.2);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--display);
  font-size: 42px;
  font-weight: 800;
  color: var(--cyan);
  position: relative;
  box-shadow: 0 0 40px rgba(0,212,255,0.1);
}

.about-avatar::before {
  content:'';
  position:absolute; inset:-6px;
  border-radius:50%;
  border: 1px solid transparent;
  background: linear-gradient(135deg, rgba(0,212,255,.3), rgba(124,106,255,.3)) border-box;
  -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: destination-out;
  mask-composite: exclude;
  animation: rotateBorder 6s linear infinite;
}

@keyframes rotateBorder {
  0%{ filter: hue-rotate(0deg); }
  100%{ filter: hue-rotate(360deg); }
}

.about-status {
  display: flex; align-items: center; gap: 5px;
  font-family: var(--mono);
  font-size: 10px;
  color: var(--green);
  padding: 4px 12px;
  border-radius: 20px;
  background: var(--green-dim);
  border: 1px solid rgba(0,229,160,.2);
}

.about-name {
  font-family: var(--display);
  font-size: 34px;
  font-weight: 800;
  color: var(--t1);
  line-height: 1;
  margin-bottom: 6px;
}

.about-title {
  font-size: 15px;
  color: var(--cyan);
  font-weight: 500;
  margin-bottom: 14px;
}

.about-bio {
  font-size: 14px;
  color: var(--t2);
  line-height: 1.7;
  max-width: 600px;
  margin-bottom: 20px;
}

.about-links {
  display: flex; gap: 10px; flex-wrap: wrap;
}

.about-link {
  display: inline-flex; align-items: center; gap: 7px;
  padding: 9px 18px;
  border-radius: var(--radius2);
  font-size: 13px;
  font-weight: 600;
  text-decoration: none;
  transition: all 0.2s;
  border: 1px solid;
}

.al-linkedin {
  background: rgba(10,102,194,.12);
  color: #0a66c2;
  border-color: rgba(10,102,194,.3);
}

.al-linkedin:hover {
  background: rgba(10,102,194,.2);
  box-shadow: 0 4px 16px rgba(10,102,194,.2);
  transform: translateY(-1px);
}

.al-email {
  background: var(--cyan-dim);
  color: var(--cyan);
  border-color: rgba(0,212,255,.3);
}

.al-email:hover {
  background: rgba(0,212,255,.15);
  box-shadow: 0 4px 16px rgba(0,212,255,.15);
  transform: translateY(-1px);
}

/* Skills */
.skill-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 10px;
}

.skill-item {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 16px;
  transition: all 0.18s;
}

.skill-item:hover { border-color: var(--border2); }

