      ).join('\n')}</div>
    `;
    grid.appendChild(card);
  });
}

function escCmd(cmd) {
  // Colorize flags and tool names
  return cmd.replace(/(-{1,2}[a-zA-Z0-9_-]+)/g, '<span class="fl">$1</span>');
}

function copyCmds(btn, cat) {
  const section = COMMANDS.find(s => s.cat === cat);
  if (!section) return;
  const text = section.cmds.map(c => `${c.comment}\n$ ${c.cmd}`).join('\n\n');
  navigator.clipboard.writeText(text).then(() => {
    btn.textContent = '✓ Copied!';
    setTimeout(() => btn.textContent = 'Copy All', 1800);
  });
}

