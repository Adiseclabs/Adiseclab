  transition: all 0.2s;
}

.astat:hover { border-color: var(--border2); transform: translateY(-2px); }

.astat-num {
  font-family: var(--display);
  font-size: 28px;
  font-weight: 800;
  color: var(--cyan);
  margin-bottom: 4px;
}

.astat-label { font-size: 11px; color: var(--t3); text-transform: uppercase; letter-spacing: 1px; }

