    `<span class="step-tag" id="st-${s}">${s.replace(/_/g,' ')}</span>`
  ).join('');

  clearTerm();
  let logI = 0;

  scanTimer = setInterval(() => {
    scanProgress = Math.min(100, scanProgress + (Math.random() * 3.5 + 0.5));
    const pct = Math.floor(scanProgress);
    document.getElementById('progFill').style.width = pct + '%';
    document.getElementById('progPct').textContent = pct + '%';

    // Steps
    const ns = Math.floor((scanProgress / 100) * SCAN_STEPS.length);
    if (ns > stepIdx && stepIdx < SCAN_STEPS.length) {
      document.getElementById('st-' + SCAN_STEPS[stepIdx])?.classList.remove('running');
      document.getElementById('st-' + SCAN_STEPS[stepIdx])?.classList.add('done');
      stepIdx = ns;
      if (stepIdx < SCAN_STEPS.length) {
        document.getElementById('st-' + SCAN_STEPS[stepIdx])?.classList.add('running');
        document.getElementById('progLabel').textContent = SCAN_STEPS[stepIdx].replace(/_/g,' ');
      }
    }

