/* ════════════════════════════════════════
   TOOL CARDS
════════════════════════════════════════ */
.tool-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
  gap: 10px;
}

.tool-item {
  background: var(--surface);
