}

.empty-findings .eicon { font-size: 40px; margin-bottom: 14px; opacity: 0.4; }
.empty-findings p { font-size: 13px; }

/* ════════════════════════════════════════
   MODULES
════════════════════════════════════════ */
.module-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 10px;
}

.module-item {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  padding: 14px 16px;
  cursor: pointer;
  transition: all 0.18s;
  position: relative;
  overflow: hidden;
}

.module-item:hover { border-color: var(--border2); transform: translateY(-1px); }

.module-item.on {
  background: rgba(0,212,255,0.04);
  border-color: rgba(0,212,255,0.2);
}

.module-item.on.crit {
  background: rgba(255,69,96,0.04);
  border-color: rgba(255,69,96,0.2);
}

.module-item.on::before {
  content:'';
  position:absolute; top:0; left:0; right:0; height:2px;
  background: var(--cyan);
  opacity: 0.6;
}

.module-item.on.crit::before { background: var(--red); }

.mod-header { display:flex; align-items:flex-start; justify-content:space-between; gap:8px; margin-bottom:8px; }
.mod-icon { font-size:18px; }

.toggle-sw {
  width: 30px; height: 16px;
  background: var(--surface3);
  border-radius: 8px;
  position: relative;
  flex-shrink: 0;
  transition: background 0.2s;
  border: 1px solid var(--border2);
}

.toggle-sw::after {
  content:'';
  position:absolute; top:2px; left:2px;
  width: 10px; height: 10px;
  border-radius: 50%;
  background: var(--t3);
  transition: all 0.2s;
}

.module-item.on .toggle-sw {
  background: var(--cyan-dim);
  border-color: rgba(0,212,255,.3);
}

.module-item.on .toggle-sw::after {
  left: 16px;
  background: var(--cyan);
  box-shadow: 0 0 6px var(--cyan);
}

.module-item.on.crit .toggle-sw { background: var(--red-dim); border-color: rgba(255,69,96,.3); }
.module-item.on.crit .toggle-sw::after { background: var(--red); box-shadow: 0 0 6px var(--red); }

.mod-name { font-size: 12px; font-weight: 600; color: var(--t1); margin-bottom: 3px; }
.mod-desc { font-size: 11px; color: var(--t3); line-height: 1.4; }

/* ════════════════════════════════════════
   COMMAND BLOCKS
════════════════════════════════════════ */
.cmd-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  margin-bottom: 14px;
}

.cmd-card-header {
  display: flex; align-items: center; justify-content: space-between;
