  border: 1px solid rgba(124,106,255,.2);
  letter-spacing: 0.5px;
}

/* ════════════════════════════════════════
   CONFIG
════════════════════════════════════════ */
.cfg-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}

.cfg-field { display: flex; flex-direction: column; gap: 6px; }

.cfg-label {
  font-family: var(--mono);
  font-size: 10px;
  color: var(--t3);
