}

.tool-item:hover {
  border-color: var(--border2);
  transform: translateY(-1px);
}

.tool-name {
  font-family: var(--mono);
  font-size: 13px;
  font-weight: 600;
  color: var(--cyan);
  margin-bottom: 5px;
}

.tool-desc {
  font-size: 11px;
  color: var(--t3);
  line-height: 1.5;
  margin-bottom: 8px;
}

.tool-cat-tag {
  font-family: var(--mono);
  font-size: 9px;
  padding: 2px 7px;
  border-radius: 3px;
