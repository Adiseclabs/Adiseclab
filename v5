    var th=document.createElement('th');th.textContent=h;
    if(i===0)th.style.width='105px';if(i===2)th.style.width='110px';
    hr.appendChild(th);
  });
  thead.appendChild(hr);
  var tbody=document.createElement('tbody');
  var svMap={critical:'c',high:'h',medium:'m',low:'l',info:'i'};
