<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>AdiSecLab — Bug Bounty Platform</title>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Syne:wght@700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#050810;--s1:#080d1a;--s2:#0c1326;--s3:#111d35;
  --b1:rgba(255,255,255,.06);--b2:rgba(255,255,255,.12);
  --cy:#00d4ff;--cyd:rgba(0,212,255,.1);
  --re:#ff4560;--red:rgba(255,69,96,.1);
  --or:#ff7b00;--ye:#ffd60a;
  --gr:#00e5a0;--grd:rgba(0,229,160,.1);
  --vi:#7c6aff;--vid:rgba(124,106,255,.12);
  --t1:#f0f4ff;--t2:#8fa3c0;--t3:#4d6480;
  --r1:10px;--r2:6px;
  --mono:'JetBrains Mono',monospace;
  --disp:'Syne',sans-serif;
  --body:'Inter',sans-serif;
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html,body{height:100%}
body{background:var(--bg);color:var(--t1);font-family:var(--body);overflow-x:hidden;-webkit-font-smoothing:antialiased}
a{text-decoration:none;color:inherit}
button{cursor:pointer;font-family:var(--body)}

/* AMBIENT */
.amb{position:fixed;inset:0;z-index:0;pointer-events:none;
  background:radial-gradient(ellipse 700px 400px at 15% -5%,rgba(0,212,255,.04) 0%,transparent 70%),
             radial-gradient(ellipse 500px 350px at 85% 110%,rgba(124,106,255,.04) 0%,transparent 70%)}
.gridbg{position:fixed;inset:0;z-index:0;pointer-events:none;
  background-image:linear-gradient(var(--b1) 1px,transparent 1px),linear-gradient(90deg,var(--b1) 1px,transparent 1px);
  background-size:44px 44px;opacity:.35}

/* LAYOUT */
.wrap{position:relative;z-index:1;display:flex;min-height:100vh}

/* SIDEBAR */
.sidebar{width:220px;flex-shrink:0;background:var(--s1);border-right:1px solid var(--b1);
  display:flex;flex-direction:column;position:fixed;top:0;bottom:0;left:0;z-index:100;
  overflow-y:auto;transition:transform .26s ease}
.sb-logo{padding:20px 16px 16px;border-bottom:1px solid var(--b1);flex-shrink:0}
.sb-mark{display:flex;align-items:center;gap:9px;margin-bottom:4px}
.sb-hex{width:34px;height:34px;border:1.5px solid var(--cy);border-radius:8px;display:flex;
  align-items:center;justify-content:center;font-family:var(--disp);font-weight:800;font-size:15px;
  color:var(--cy);background:var(--cyd);flex-shrink:0;box-shadow:0 0 14px rgba(0,212,255,.15)}
.sb-word{font-family:var(--disp);font-size:16px;font-weight:800;color:var(--t1)}
.sb-tag{font-family:var(--mono);font-size:9px;color:var(--t3);letter-spacing:2px;text-transform:uppercase;margin-bottom:7px}
.sb-ver{display:inline-block;font-family:var(--mono);font-size:9px;padding:2px 8px;border-radius:10px;
  background:var(--cyd);color:var(--cy);border:1px solid rgba(0,212,255,.2)}
.sb-sec{padding:12px 16px 4px;font-family:var(--mono);font-size:9px;color:var(--t3);letter-spacing:2px;text-transform:uppercase;flex-shrink:0}
.nav-btn{display:flex;align-items:center;gap:8px;padding:9px 13px;margin:1px 7px;
  border-radius:var(--r2);border:1px solid transparent;font-size:13px;font-weight:500;
  color:var(--t2);background:transparent;transition:all .15s;width:calc(100% - 14px);
  text-align:left;position:relative;white-space:nowrap}
.nav-btn:hover{background:var(--s2);color:var(--t1)}
.nav-btn.on{background:var(--cyd);color:var(--cy);border-color:rgba(0,212,255,.15)}
.nav-btn.on::before{content:'';position:absolute;left:-7px;top:50%;transform:translateY(-50%);
  width:3px;height:16px;background:var(--cy);border-radius:0 2px 2px 0;box-shadow:0 0 6px var(--cy)}
.nav-ico{font-size:14px;width:18px;text-align:center;flex-shrink:0}
.nav-bdg{margin-left:auto;font-family:var(--mono);font-size:9px;padding:1px 6px;
  border-radius:8px;background:var(--red);color:var(--re);border:1px solid rgba(255,69,96,.2)}
.sb-foot{margin-top:auto;padding:12px 9px;border-top:1px solid var(--b1);flex-shrink:0}
.dev-card{display:flex;align-items:center;gap:8px;padding:10px 11px;background:var(--s2);
  border-radius:var(--r1);border:1px solid var(--b1);transition:all .16s}
.dev-card:hover{border-color:var(--b2);background:var(--s3)}
.dev-av{width:30px;height:30px;border-radius:6px;background:linear-gradient(135deg,var(--cy),var(--vi));
  display:flex;align-items:center;justify-content:center;font-family:var(--disp);font-size:11px;
  font-weight:800;color:#000;flex-shrink:0}
.dev-nm{font-size:12px;font-weight:600;color:var(--t1);line-height:1.2}
.dev-rl{font-family:var(--mono);font-size:9px;color:var(--t3);letter-spacing:1px}

/* MAIN */
.main{margin-left:220px;flex:1;display:flex;flex-direction:column;min-height:100vh}
.topbar{height:56px;display:flex;align-items:center;justify-content:space-between;
  padding:0 24px;background:rgba(8,13,26,.9);border-bottom:1px solid var(--b1);
  backdrop-filter:blur(10px);position:sticky;top:0;z-index:50;flex-shrink:0}
.tb-l{display:flex;align-items:center;gap:7px;font-size:13px;color:var(--t2)}
.tb-l strong{color:var(--t1);font-weight:600}
.tb-sep{color:var(--t3)}
.tb-r{display:flex;align-items:center;gap:11px}
.sys-pill{display:flex;align-items:center;gap:5px;font-family:var(--mono);font-size:10px;
  color:var(--gr);padding:4px 10px;border-radius:20px;background:var(--grd);border:1px solid rgba(0,229,160,.2)}
.dot{width:6px;height:6px;border-radius:50%;background:var(--gr);box-shadow:0 0 5px var(--gr);
  animation:pulse 2s ease-in-out infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.35}}
#clock{font-family:var(--mono);font-size:11px;color:var(--t3);letter-spacing:1px}

/* PAGES */
.page{display:none;padding:24px 24px 60px;animation:fin .18s ease}
.page.on{display:block}
@keyframes fin{from{opacity:0;transform:translateY(5px)}to{opacity:1;transform:translateY(0)}}
.pg-h{margin-bottom:22px}
.pg-t{font-family:var(--disp);font-size:22px;font-weight:800;color:var(--t1);margin-bottom:4px}
.pg-s{font-size:13px;color:var(--t2);line-height:1.5}

/* CARD */
.card{background:var(--s1);border:1px solid var(--b1);border-radius:var(--r1);overflow:hidden;transition:border-color .15s}
.card:hover{border-color:var(--b2)}
.c-head{display:flex;align-items:center;justify-content:space-between;padding:11px 15px;
  border-bottom:1px solid var(--b1);background:rgba(255,255,255,.01)}
.c-title{display:flex;align-items:center;gap:6px;font-family:var(--mono);font-size:11px;
  font-weight:600;color:var(--t2);letter-spacing:1px;text-transform:uppercase}
.c-body{padding:15px}

/* CHIP */
.chip{display:inline-flex;align-items:center;font-family:var(--mono);font-size:10px;
  padding:3px 9px;border-radius:20px;border:1px solid;letter-spacing:.5px;font-weight:500}
.ch-cy{color:var(--cy);background:var(--cyd);border-color:rgba(0,212,255,.2)}
.ch-re{color:var(--re);background:var(--red);border-color:rgba(255,69,96,.2)}
.ch-gr{color:var(--gr);background:var(--grd);border-color:rgba(0,229,160,.2)}
.ch-vi{color:var(--vi);background:var(--vid);border-color:rgba(124,106,255,.2)}

/* GRID */
.g2{display:grid;grid-template-columns:1fr 1fr;gap:15px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:15px}

/* BUTTONS */
.btn{display:inline-flex;align-items:center;justify-content:center;gap:5px;
  padding:8px 16px;border-radius:var(--r2);font-size:13px;font-weight:600;
  border:1px solid transparent;transition:all .15s;white-space:nowrap;line-height:1}
.btn:disabled{opacity:.4;cursor:not-allowed}
.b-cy{background:var(--cy);color:#050810;border-color:var(--cy);box-shadow:0 2px 12px rgba(0,212,255,.2)}
.b-cy:hover{background:#22ddff;box-shadow:0 2px 20px rgba(0,212,255,.35);transform:translateY(-1px)}
.b-gh{background:transparent;color:var(--t2);border-color:var(--b2)}
.b-gh:hover{background:var(--s2);color:var(--t1);border-color:rgba(255,255,255,.18)}
.b-re{background:var(--red);color:var(--re);border-color:rgba(255,69,96,.25)}
.b-re:hover{background:rgba(255,69,96,.18)}
.b-pdf{background:rgba(255,69,96,.08);color:#ff6090;border-color:rgba(255,69,96,.3)}
.b-pdf:hover{background:rgba(255,69,96,.16)}
.b-scan{background:var(--cy);color:#050810;border-color:var(--cy);padding:10px 22px;font-size:14px;
  box-shadow:0 2px 14px rgba(0,212,255,.25)}
.b-scan:hover{background:#22ddff;box-shadow:0 2px 22px rgba(0,212,255,.4);transform:translateY(-1px)}
.b-stop{background:var(--re);border-color:var(--re);color:#fff;
  box-shadow:0 2px 14px rgba(255,69,96,.3);animation:scanp 2s ease-in-out infinite}
@keyframes scanp{0%,100%{box-shadow:0 2px 14px rgba(255,69,96,.3)}50%{box-shadow:0 2px 24px rgba(255,69,96,.55)}}
.b-sm{padding:6px 13px;font-size:12px}
.b-xs{padding:4px 9px;font-size:11px}

/* SCAN BAR */
.scan-bar{background:var(--s1);border:1px solid var(--b1);border-radius:var(--r1);
  padding:18px 18px 15px;margin-bottom:16px;position:relative;overflow:hidden}
.scan-bar::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,transparent,var(--cy),var(--vi),transparent);opacity:.5}
.s-label{font-family:var(--mono);font-size:9px;color:var(--t3);letter-spacing:2px;text-transform:uppercase;margin-bottom:7px}
.s-row{display:flex;gap:8px;align-items:center;flex-wrap:wrap}
.s-inp{flex:1;min-width:240px;background:var(--s2);border:1px solid var(--b2);border-radius:var(--r2);
  padding:10px 13px;font-family:var(--mono);font-size:13px;color:var(--cy);outline:none;
  transition:all .18s;caret-color:var(--cy)}
.s-inp:focus{border-color:rgba(0,212,255,.4);background:var(--s3);box-shadow:0 0 0 3px rgba(0,212,255,.06)}
.s-inp::placeholder{color:var(--t3)}
.mode-row{display:flex;gap:6px;flex-wrap:wrap;margin-top:11px}
.mdbtn{padding:5px 12px;border-radius:20px;font-size:12px;font-weight:500;
  border:1px solid var(--b2);color:var(--t2);background:transparent;transition:all .15s}
.mdbtn:hover{color:var(--t1)}
.mdbtn.on{font-weight:700}
.md-r.on{background:var(--cyd);color:var(--cy);border-color:rgba(0,212,255,.3)}
.md-v.on{background:var(--red);color:var(--re);border-color:rgba(255,69,96,.3)}
.md-f.on{background:rgba(255,123,0,.1);color:var(--or);border-color:rgba(255,123,0,.3)}
.md-o.on{background:var(--vid);color:var(--vi);border-color:rgba(124,106,255,.3)}
.md-a.on{background:rgba(255,214,10,.08);color:var(--ye);border-color:rgba(255,214,10,.25)}
.md-g.on{background:linear-gradient(90deg,var(--cyd),var(--vid));color:var(--t1);border-color:rgba(0,212,255,.3)}

/* STATS */
.stats{display:grid;grid-template-columns:repeat(5,1fr);gap:11px;margin-bottom:16px}
.sc{background:var(--s1);border:1px solid var(--b1);border-radius:var(--r1);padding:14px 15px;
  position:relative;overflow:hidden;transition:all .18s}
.sc:hover{border-color:var(--b2);transform:translateY(-2px)}
.sc::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px}
.sc-c::after{background:linear-gradient(90deg,transparent,var(--re),transparent)}
.sc-h::after{background:linear-gradient(90deg,transparent,var(--or),transparent)}
.sc-m::after{background:linear-gradient(90deg,transparent,var(--ye),transparent)}
.sc-l::after{background:linear-gradient(90deg,transparent,var(--gr),transparent)}
.sc-i::after{background:linear-gradient(90deg,transparent,var(--cy),transparent)}
.sc-n{font-family:var(--disp);font-size:32px;font-weight:800;line-height:1;margin-bottom:4px}
.sc-c .sc-n{color:var(--re)}.sc-h .sc-n{color:var(--or)}.sc-m .sc-n{color:var(--ye)}
.sc-l .sc-n{color:var(--gr)}.sc-i .sc-n{color:var(--cy)}
.sc-lb{font-size:10px;color:var(--t3);text-transform:uppercase;letter-spacing:1px}
.sc-ico{position:absolute;top:11px;right:11px;font-size:18px;opacity:.1}

/* PROGRESS */
.prog{background:var(--s1);border:1px solid var(--b1);border-radius:var(--r1);
  padding:16px 18px;margin-bottom:16px;display:none}
.prog.on{display:block}
.prog-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:9px}
.prog-l{display:flex;align-items:center;gap:8px}
.spin{width:13px;height:13px;border:2px solid var(--b2);border-top-color:var(--cy);
  border-radius:50%;animation:sp .7s linear infinite}
@keyframes sp{to{transform:rotate(360deg)}}
.prog-lbl{font-family:var(--mono);font-size:10px;color:var(--t2);letter-spacing:1.5px;text-transform:uppercase}
.prog-pct{font-family:var(--disp);font-size:20px;font-weight:800;color:var(--cy)}
.prog-track{height:4px;background:var(--s3);border-radius:2px;overflow:hidden;margin-bottom:11px}
.prog-fill{height:100%;border-radius:2px;background:linear-gradient(90deg,var(--vi),var(--cy));
  width:0%;transition:width .3s ease}
.steps{display:flex;gap:4px;flex-wrap:wrap}
.step{font-family:var(--mono);font-size:9px;padding:2px 6px;border-radius:3px;
  border:1px solid var(--b1);color:var(--t3);transition:all .2s;letter-spacing:.5px}
.step.done{border-color:rgba(0,229,160,.3);color:var(--gr);background:var(--grd)}
.step.run{border-color:rgba(0,212,255,.3);color:var(--cy);background:var(--cyd);
  animation:sb .8s ease-in-out infinite}
@keyframes sb{0%,100%{opacity:1}50%{opacity:.45}}

/* TERMINAL */
.term{background:#020508;border:1px solid var(--b1);border-radius:var(--r1);overflow:hidden;margin-bottom:16px}
.term-bar{display:flex;align-items:center;gap:5px;padding:8px 12px;
  background:var(--s1);border-bottom:1px solid var(--b1)}
.td{width:10px;height:10px;border-radius:50%}
.td-r{background:#ff5f57}.td-y{background:#febc2e}.td-g{background:#28c840}
.term-ttl{font-family:var(--mono);font-size:11px;color:var(--t3);margin-left:7px;flex:1}
.term-acts{display:flex;gap:5px}
.tbtn{font-family:var(--mono);font-size:10px;padding:3px 8px;border-radius:4px;
  background:transparent;border:1px solid var(--b2);color:var(--t3);transition:all .14s}
.tbtn:hover{color:var(--t1);border-color:var(--b2)}
.term-body{height:260px;overflow-y:auto;padding:11px 13px;font-family:var(--mono);
  font-size:12px;line-height:1.9;scrollbar-width:thin;scrollbar-color:var(--s3) transparent}
.term-body::-webkit-scrollbar{width:3px}
.term-body::-webkit-scrollbar-thumb{background:var(--s3);border-radius:2px}
.tl{display:flex;gap:8px;align-items:flex-start}
.tts{color:var(--t3);font-size:10px;flex-shrink:0;padding-top:2px;min-width:52px}
.ttag{font-size:9px;font-weight:700;padding:2px 5px;border-radius:3px;flex-shrink:0;letter-spacing:.5px}
.t-sys{background:var(--vid);color:var(--vi)}.t-inf{background:var(--cyd);color:var(--cy)}
.t-ok{background:var(--grd);color:var(--gr)}.t-w{background:rgba(255,214,10,.08);color:var(--ye)}
.t-cr{background:var(--red);color:var(--re)}
.tmsg{color:var(--t1);flex:1;word-break:break-all;line-height:1.6}
.h{color:var(--cy)}.r{color:var(--re)}.g{color:var(--gr)}.y{color:var(--ye)}.v{color:var(--vi)}.o{color:var(--or)}

/* FINDINGS TABLE */
.ftbl{width:100%;border-collapse:collapse}
.ftbl thead tr{border-bottom:1px solid var(--b2)}
.ftbl th{font-family:var(--mono);font-size:10px;color:var(--t3);letter-spacing:1.5px;
  text-transform:uppercase;padding:9px 13px;text-align:left;font-weight:500}
.ftbl tbody tr{border-bottom:1px solid var(--b1);transition:background .12s}
.ftbl tbody tr:hover{background:var(--s2)}
.ftbl tbody tr:last-child{border-bottom:none}
.ftbl td{padding:11px 13px;vertical-align:top}
.sv{display:inline-flex;align-items:center;padding:3px 8px;border-radius:4px;
  font-size:10px;font-weight:700;font-family:var(--mono);letter-spacing:.5px;border:1px solid;white-space:nowrap}
.sv-c{background:var(--red);color:var(--re);border-color:rgba(255,69,96,.3)}
.sv-h{background:rgba(255,123,0,.1);color:var(--or);border-color:rgba(255,123,0,.3)}
.sv-m{background:rgba(255,214,10,.08);color:var(--ye);border-color:rgba(255,214,10,.25)}
.sv-l{background:var(--grd);color:var(--gr);border-color:rgba(0,229,160,.25)}
.sv-i{background:var(--cyd);color:var(--cy);border-color:rgba(0,212,255,.2)}
.fn{color:var(--t1);font-weight:500;font-size:13px;margin-bottom:2px}
.fu{font-family:var(--mono);font-size:10px;color:var(--t3);margin-bottom:3px}
.fd{font-size:11px;color:var(--t2);line-height:1.5}
.empty{text-align:center;padding:46px 20px;color:var(--t3)}
.empty .ei{font-size:34px;margin-bottom:11px;opacity:.3}
.empty p{font-size:13px}

/* EXPORT BAR */
.xbar{display:flex;gap:8px;flex-wrap:wrap;padding:12px 15px;border-top:1px solid var(--b1);background:rgba(255,255,255,.01)}

/* MODULES */
.mod-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(192px,1fr));gap:8px}
.mod{background:var(--s1);border:1px solid var(--b1);border-radius:var(--r1);
  padding:12px 14px;cursor:pointer;transition:all .15s;position:relative;overflow:hidden;user-select:none}
.mod:hover{border-color:var(--b2);transform:translateY(-1px)}
.mod.on{background:rgba(0,212,255,.03);border-color:rgba(0,212,255,.2)}
.mod.on.cr{background:rgba(255,69,96,.03);border-color:rgba(255,69,96,.2)}
.mod.on::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--cy);opacity:.6}
.mod.on.cr::before{background:var(--re)}
.mod-hd{display:flex;align-items:flex-start;justify-content:space-between;gap:7px;margin-bottom:7px}
.mod-ic{font-size:16px}
.tsw{width:26px;height:14px;background:var(--s3);border-radius:7px;position:relative;
  flex-shrink:0;border:1px solid var(--b2);transition:all .18s}
.tsw::after{content:'';position:absolute;top:2px;left:2px;width:8px;height:8px;
  border-radius:50%;background:var(--t3);transition:all .18s}
.mod.on .tsw{background:var(--cyd);border-color:rgba(0,212,255,.3)}
.mod.on .tsw::after{left:14px;background:var(--cy)}
.mod.on.cr .tsw{background:var(--red);border-color:rgba(255,69,96,.3)}
.mod.on.cr .tsw::after{left:14px;background:var(--re)}
.mod-nm{font-size:12px;font-weight:600;color:var(--t1);margin-bottom:2px}
.mod-ds{font-size:11px;color:var(--t3);line-height:1.4}

/* COMMANDS */
.cmd-pre{background:#020508;padding:12px 14px;font-family:var(--mono);font-size:12px;
  line-height:1.8;color:var(--gr);overflow-x:auto;white-space:pre;tab-size:2}
.cmd-hd{display:flex;align-items:center;justify-content:space-between;
  padding:9px 14px;border-bottom:1px solid var(--b1);background:rgba(255,255,255,.01)}
.cmd-cat{font-family:var(--mono);font-size:11px;font-weight:600;color:var(--t2);letter-spacing:1px}
.cpbtn{font-family:var(--mono);font-size:10px;padding:3px 9px;border-radius:4px;
  background:var(--cyd);border:1px solid rgba(0,212,255,.2);color:var(--cy);transition:all .14s}
.cpbtn:hover{background:rgba(0,212,255,.18)}

/* TOOLS */
.tool-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(198px,1fr));gap:8px}
.tool-item{background:var(--s1);border:1px solid var(--b1);border-radius:var(--r1);
  padding:12px 14px;transition:all .15s}
.tool-item:hover{border-color:var(--b2);transform:translateY(-1px)}
.tool-nm{font-family:var(--mono);font-size:13px;font-weight:600;color:var(--cy);margin-bottom:3px}
.tool-ds{font-size:11px;color:var(--t3);line-height:1.4;margin-bottom:6px}
.tool-cat{font-family:var(--mono);font-size:9px;padding:2px 7px;border-radius:3px;
  background:var(--vid);color:var(--vi);border:1px solid rgba(124,106,255,.2)}

/* CONFIG */
.cfg-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.cfg-f{display:flex;flex-direction:column;gap:5px}
.cfg-lb{font-family:var(--mono);font-size:10px;color:var(--t3);letter-spacing:1.5px;text-transform:uppercase}
.cfg-in,.cfg-sl{background:var(--s2);border:1px solid var(--b2);border-radius:var(--r2);
