  transition:all .18s;width:100%}
.cfg-in:focus,.cfg-sl:focus{border-color:rgba(0,212,255,.35);background:var(--s3)}
.cfg-sl option{background:#0c1326}
.itbl{width:100%;border-collapse:collapse}
.itbl tr{border-bottom:1px solid var(--b1)}
.itbl tr:last-child{border-bottom:none}
.itbl td{padding:9px 13px;font-size:12px}
.itbl td:first-child{font-family:var(--mono);color:var(--t3);font-size:10px;letter-spacing:1px;width:44%}

/* PAYLOADS */
.pl-sec{margin-bottom:16px}
.pl-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(265px,1fr));gap:6px}
.pl-chip{background:#020508;border:1px solid var(--b2);border-radius:var(--r2);
  padding:8px 11px;font-family:var(--mono);font-size:11px;color:var(--gr);
