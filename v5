    +'.crisk{display:inline-block;padding:7px 20px;border-radius:4px;font-weight:800;font-size:14px;letter-spacing:2px;margin:12px 0;position:relative;z-index:1}'
    +'.rb{background:rgba(255,255,255,.1);border-radius:20px;height:8px;overflow:hidden;margin:7px 0 3px;width:320px}'
    +'.rf{height:100%;border-radius:20px;background:linear-gradient(90deg,#00e5a0,#ffd60a,#ff7b00,#ff4560)}'
    +'.cm{font-size:11px;color:#8fa3c0;margin-top:16px;line-height:2;position:relative;z-index:1}'
    +'.cd{font-family:JetBrains Mono,monospace;font-size:10px;color:#4d6480;margin-top:22px;letter-spacing:1px;position:relative;z-index:1}'
    +'.wrap{padding-top:18px}.sh{margin:24px 0 12px;padding-bottom:7px;border-bottom:2px solid #f0f0f0;display:flex;align-items:center;gap:8px}'
    +'.sh h2{font-size:16px;font-weight:700;color:#111}'
    +'.sg{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:16px}'
    +'.sb{text-align:center;padding:13px;border-radius:7px;border:1px solid}'
    +'.sn{font-size:28px;font-weight:800;line-height:1}.sl{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-top:3px;color:#666}'
    +'.ebox{background:#f8f9ff;border:1px solid #dde2ff;border-radius:7px;padding:15px;margin-bottom:15px}'
    +'.ebox h3{font-size:13px;font-weight:700;color:#3040aa;margin-bottom:6px}'
    +'.toc-i{display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px dotted #e0e0e0;font-size:12px}'
    +'footer{text-align:center;padding:16px;border-top:1px solid #e0e0e0;margin-top:26px;font-size:11px;color:#aaa}'
    +'</style></head><body>'
    +'<div class="cover"><div class="cg"></div><div class="cl">A</div>'
    +'<div class="ct">AdiSecLab v5.0.0</div><h1>Security Assessment Report</h1>'
    +'<div class="ctg">'+tgt+'</div>'
    +'<div class="crisk" style="background:'+rcol+'22;color:'+rcol+';border:2px solid '+rcol+'">\u26a0 '+rlbl+' \u2014 Score: '+score+'/100</div>'
    +'<div class="rb"><div class="rf" style="width:'+score+'%"></div></div>'
    +'<div class="cm">Scan Date: '+now.toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'})+' at '+now.toLocaleTimeString('en-US',{hour12:false})+'<br>Mode: '+scanMode+' | Vulnerabilities Found: '+findings.length+'</div>'
    +'<div class="cd">Prepared by: Aditya Bhosale | adityabhosale212223@gmail.com<br>linkedin.com/in/bhsoaleaditya | AdiSecLab Bug Bounty Intelligence Platform</div>'
    +'</div>'
    +'<div class="wrap" style="page-break-before:always">'
    +'<div class="sh"><h2>\uD83D\uDCCA Executive Summary</h2></div>'
    +'<div class="ebox"><h3>Overall Risk: '+rlbl+' ('+score+'/100)</h3><p style="font-size:13px;color:#333;line-height:1.7">Assessment of <strong>'+tgt+'</strong> found <strong>'+findings.length+' vulnerabilities</strong>. Risk score: <strong style="color:'+rcol+'">'+score+'/100</strong>.</p></div>'
    +'<div class="sg">'
    +'<div class="sb" style="background:#fff0f2;border-color:#ffc0cc"><div class="sn" style="color:#ff4560">'+c.critical+'</div><div class="sl">Critical</div></div>'
    +'<div class="sb" style="background:#fff5ef;border-color:#ffd0b0"><div class="sn" style="color:#ff7b00">'+c.high+'</div><div class="sl">High</div></div>'
    +'<div class="sb" style="background:#fffbef;border-color:#ffe080"><div class="sn" style="color:#cc9900">'+c.medium+'</div><div class="sl">Medium</div></div>'
    +'<div class="sb" style="background:#f0fff8;border-color:#b0f0d8"><div class="sn" style="color:#00a060">'+c.low+'</div><div class="sl">Low</div></div>'
    +'<div class="sb" style="background:#f0faff;border-color:#a0e0ff"><div class="sn" style="color:#0099cc">'+c.info+'</div><div class="sl">Info</div></div>'
