.ast-l{font-size:10px;color:var(--t3);text-transform:uppercase;letter-spacing:1px}
.sk-i{background:var(--s1);border:1px solid var(--b1);border-radius:var(--r1);padding:13px}
.sk-n{font-weight:600;font-size:13px;color:var(--t1);margin-bottom:6px}
.sk-bar{height:4px;background:var(--s3);border-radius:2px;overflow:hidden;margin-bottom:3px}
.sk-fill{height:100%;border-radius:2px;background:linear-gradient(90deg,var(--vi),var(--cy))}
.sk-pct{font-family:var(--mono);font-size:10px;color:var(--t3)}
.tp{display:inline-block;font-family:var(--mono);font-size:11px;padding:3px 9px;
  border-radius:5px;background:var(--s2);border:1px solid var(--b2);color:var(--t2);margin:3px;transition:all .14s}
.tp:hover{color:var(--cy);border-color:rgba(0,212,255,.25);background:var(--cyd)}

/* MODAL */
.modal{display:none;position:fixed;inset:0;z-index:999;
  background:rgba(0,0,0,.8);backdrop-filter:blur(6px);overflow-y:auto}
.modal.on{display:block}
.modal-in{max-width:840px;margin:36px auto;padding:0 16px 48px}

/* NOTIFS */
#notifs{position:fixed;bottom:18px;right:18px;display:flex;flex-direction:column;gap:7px;z-index:9999;pointer-events:none}
.notif{background:var(--s2);border:1px solid var(--b2);border-left:3px solid var(--cy);
  border-radius:var(--r1);padding:10px 14px;font-size:12px;color:var(--t1);max-width:280px;
  backdrop-filter:blur(12px);box-shadow:0 5px 18px rgba(0,0,0,.4);
  animation:nin .2s ease;pointer-events:all}
.notif.ok{border-left-color:var(--gr)}.notif.warn{border-left-color:var(--ye)}.notif.err{border-left-color:var(--re)}
@keyframes nin{from{transform:translateX(16px);opacity:0}to{transform:translateX(0);opacity:1}}

/* MOBILE */
.mob-tog{display:none;position:fixed;top:10px;left:10px;z-index:200;
