/* ═══ SCAN ENGINE ═══ */
function toggleScan(){if(scanning)stopScan();else startScan();}

function startScan(){
  var tgt=document.getElementById('target').value.trim();
  if(!tgt){notify('Enter a target first','warn');document.getElementById('target').focus();return;}

  scanning=true;findings=[];findIdx=0;logIdx=0;progress=0;stepI=0;
  logLines=LOG_LINES(tgt);

  var btn=document.getElementById('scan-btn');
  btn.textContent='\u23F9 Stop Scan';btn.className='btn b-stop';

  document.getElementById('prog').classList.add('on');
  document.getElementById('exp-top').style.display='none';
  document.getElementById('xbar').style.display='none';
  ['s-c','s-h','s-m','s-l','s-i'].forEach(function(id){document.getElementById(id).textContent='0';});
  document.getElementById('findings-area').innerHTML='<div class="empty"><div class="ei">\u23F3</div><p>Scan in progress\u2026</p></div>';
  document.getElementById('find-chip').textContent='0 Findings';
  document.getElementById('nb-f').style.display='none';
  document.getElementById('spin').style.display='';

  // Build steps
  var sr=document.getElementById('steps');sr.innerHTML='';
  STEPS.forEach(function(s){
    var t=document.createElement('span');
    t.className='step';t.id='st-'+s;t.textContent=s;
    sr.appendChild(t);
  });

  document.getElementById('term-body').innerHTML='';
  addLog('sys','<span class="v">AdiSecLab v5.0</span> by <span class="h">Aditya Bhosale</span> \u2014 scan started');
  addLog('inf','Target: <span class="h">'+tgt+'</span> | Mode: <span class="y">'+scanMode+'</span>');

  timer=setInterval(function(){
    progress=Math.min(100,progress+(Math.random()*3+0.5));
    var pct=Math.floor(progress);
    document.getElementById('prog-fill').style.width=pct+'%';
    document.getElementById('prog-pct').textContent=pct+'%';

    // Step tracking
    var ns=Math.min(Math.floor((progress/100)*STEPS.length),STEPS.length-1);
    if(ns>stepI){
      var prev=document.getElementById('st-'+STEPS[stepI]);
      if(prev){prev.classList.remove('run');prev.classList.add('done');}
      stepI=ns;
      var cur=document.getElementById('st-'+STEPS[stepI]);
      if(cur){cur.classList.add('run');document.getElementById('prog-lbl').textContent=STEPS[stepI];}
    }

    // Log lines
    if(logIdx<logLines.length&&Math.random()>0.4){
      var ll=logLines[logIdx++];
      addLog(ll[0],ll[1]);
    }

    // Drip findings
    if(progress>28&&findIdx<FINDINGS.length&&Math.random()>0.52){
      findings.push(FINDINGS[findIdx++]);
      renderFindings();updateStats();
    }

    if(progress>=100){
      while(findIdx<FINDINGS.length){findings.push(FINDINGS[findIdx++]);}
      STEPS.forEach(function(s){
        var e=document.getElementById('st-'+s);
        if(e){e.classList.remove('run');e.classList.add('done');}
      });
      renderFindings();updateStats();
      stopScan(true);
    }
  },260);
}

function stopScan(done){
  scanning=false;
  if(timer){clearInterval(timer);timer=null;}
  var btn=document.getElementById('scan-btn');
  btn.textContent='\u25B6 Launch Scan';btn.className='btn b-scan';
  document.getElementById('spin').style.display='none';
  if(done){
    document.getElementById('prog-fill').style.width='100%';
    document.getElementById('prog-pct').textContent='100%';
    document.getElementById('prog-lbl').textContent='COMPLETE';
    document.getElementById('exp-top').style.display='';
    if(findings.length)document.getElementById('xbar').style.display='flex';
    notify('Scan complete \u2014 '+findings.length+' vulnerabilities found!','ok');
    addLog('ok','<span class="g">\u2713 Complete.</span> '+findings.length+' findings \u2014 see Findings tab.');
  }else if(done===false){
    document.getElementById('prog-lbl').textContent='STOPPED';
    notify('Scan stopped','warn');
    addLog('w','Scan stopped by user.');
  }
}

function clearAll(){
  if(scanning)stopScan(false);
