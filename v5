    +'.cover{background:linear-gradient(135deg,#050810,#0c1326);color:#fff;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:50px 36px;page-break-after:always;position:relative}'
