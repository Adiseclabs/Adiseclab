.pl-done{border-color:rgba(0,229,160,.4)!important;color:var(--gr)!important;background:var(--grd)!important}

/* NOTES */
.note-ta{width:100%;background:#020508;border:1px solid var(--b2);border-radius:var(--r2);
  padding:11px 13px;font-family:var(--mono);font-size:12px;color:var(--gr);
