      return '<div class="toc-i"><span style="font-family:monospace;font-size:10px;color:#888;width:22px">'+String(i+1).padStart(2,'0')+'</span><span style="padding:2px 7px;border-radius:3px;font-size:10px;font-weight:700;'+sc(f.sv)+'">'+f.sv.toUpperCase()+'</span><span>'+f.nm+'</span><span style="margin-left:auto;font-family:monospace;font-size:11px;color:#888">'+f.tl+'</span></div>';
