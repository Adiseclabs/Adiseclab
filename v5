/* ═══ DETAIL VIEW ═══ */
function openDetail(){
  if(!findings.length){notify('No findings','warn');return;}
  var c={critical:0,high:0,medium:0,low:0,info:0};findings.forEach(function(f){c[f.sv]++;});
  var score=Math.min(100,c.critical*25+c.high*12+c.medium*5+c.low*2);
  var rcol=score>=75?'var(--re)':score>=50?'var(--or)':score>=25?'var(--ye)':'var(--gr)';
  var svCol={critical:'var(--re)',high:'var(--or)',medium:'var(--ye)',low:'var(--gr)',info:'var(--cy)'};
  var body=document.getElementById('detail-body');body.innerHTML='';

  var intro=document.createElement('div');
  intro.innerHTML='<div style="display:flex;align-items:center;gap:14px;margin-bottom:11px">'
    +'<div style="font-family:var(--disp);font-size:42px;font-weight:800;color:'+rcol+'">'+score+'</div>'
    +'<div><div style="font-size:13px;font-weight:600;color:var(--t1);margin-bottom:3px">'+(score>=75?'CRITICAL RISK':score>=50?'HIGH RISK':score>=25?'MEDIUM RISK':'LOW RISK')+'</div>'
    +'<div style="font-size:12px;color:var(--t2)">'+findings.length+' vulnerabilities</div></div></div>'
    +'<div style="height:4px;background:var(--s3);border-radius:2px;overflow:hidden;margin-bottom:13px"><div style="height:100%;width:'+score+'%;background:linear-gradient(90deg,var(--vi),var(--re));border-radius:2px"></div></div>'
    +'<div style="display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:16px">'
    +Object.keys(c).map(function(sv){return'<div style="text-align:center;padding:11px;background:var(--s2);border-radius:8px;border:1px solid var(--b1)"><div style="font-family:var(--disp);font-size:22px;font-weight:800;color:'+svCol[sv]+'">'+c[sv]+'</div><div style="font-size:10px;color:var(--t3);text-transform:uppercase;letter-spacing:1px">'+sv+'</div></div>';}).join('')
    +'</div>';
  body.appendChild(intro);

  findings.forEach(function(f){
    var rem=REMEDIATION[f.sv]||REMEDIATION.info;
    var fx=TOOL_FIX[f.tl]||TOOL_FIX.default;
    var card=document.createElement('div');
    card.style.cssText='border:1px solid var(--b1);border-radius:8px;overflow:hidden;margin-bottom:11px';
    var hd=document.createElement('div');
    hd.style.cssText='padding:10px 14px;background:var(--s2);border-bottom:1px solid var(--b1);display:flex;align-items:center;gap:8px';
    var badge=document.createElement('span');
    badge.style.cssText='padding:2px 8px;border-radius:3px;font-size:10px;font-weight:700;background:'+svCol[f.sv]+';color:'+(f.sv==='medium'||f.sv==='low'?'#000':'#fff');
    badge.textContent=f.sv.toUpperCase();
    var nm=document.createElement('span');nm.style.cssText='font-weight:600;color:var(--t1)';nm.textContent=f.nm;
    var tl=document.createElement('span');tl.style.cssText='margin-left:auto;font-family:var(--mono);font-size:10px;color:var(--vi)';tl.textContent=f.tl;
    hd.appendChild(badge);hd.appendChild(nm);hd.appendChild(tl);
    var bd=document.createElement('div');bd.style.cssText='padding:12px 14px';
    var url=document.createElement('div');url.style.cssText='font-family:var(--mono);font-size:11px;color:var(--t3);margin-bottom:6px';url.textContent=f.url;
    var ds=document.createElement('div');ds.style.cssText='font-size:12px;color:var(--t2);margin-bottom:11px;line-height:1.6';ds.textContent=f.ds;
    var grid=document.createElement('div');grid.style.cssText='display:grid;grid-template-columns:1fr 1fr;gap:8px;font-size:11px';
    function mk(bg,bc,lc,lb,tx){var d=document.createElement('div');d.style.cssText='background:'+bg+';border:1px solid '+bc+';border-radius:6px;padding:9px';var l=document.createElement('div');l.style.cssText='color:'+lc+';font-family:var(--mono);font-size:9px;letter-spacing:1.5px;margin-bottom:4px';l.textContent=lb;var t=document.createElement('div');t.style.cssText='color:var(--t2);line-height:1.6';t.textContent=tx;d.appendChild(l);d.appendChild(t);return d;}
    grid.appendChild(mk('rgba(0,212,255,.05)','rgba(0,212,255,.15)','var(--cy)','WHAT TO FOCUS',rem.focus));
    grid.appendChild(mk('rgba(0,229,160,.05)','rgba(0,229,160,.15)','var(--gr)','HOW TO USE '+f.tl,fx.how));
    var fx2=mk('rgba(255,123,0,.05)','rgba(255,123,0,.15)','var(--or)','FIX / REMEDIATION',fx.fix);
    fx2.style.gridColumn='1/-1';grid.appendChild(fx2);
    bd.appendChild(url);bd.appendChild(ds);bd.appendChild(grid);
    card.appendChild(hd);card.appendChild(bd);body.appendChild(card);
  });
  document.getElementById('detail-modal').classList.add('on');
}

/* ═══ NOTIFY ═══ */
function notify(msg,type){
  var area=document.getElementById('notifs');
  var el=document.createElement('div');
  el.className='notif'+(type?' '+type:'');
  el.textContent=msg;
  area.appendChild(el);
  setTimeout(function(){
    el.style.cssText='animation:nin .2s ease reverse;opacity:0;transform:translateX(16px)';
    setTimeout(function(){if(el.parentNode)el.parentNode.removeChild(el);},220);
  },2800);
}

/* ═══ BOOT ═══ */
document.addEventListener('DOMContentLoaded',init);

})();
