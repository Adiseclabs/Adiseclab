    +(c.critical>0?'<div style="background:#fff0f2;border-left:4px solid #ff4560;border-radius:4px;padding:10px 14px;margin-bottom:13px"><strong style="color:#ff4560">\u26a0 Critical Alert:</strong> <span style="font-size:13px;color:#333">'+c.critical+' critical vulnerabilities require immediate remediation.</span></div>':'')
