.note-ta:focus{border-color:rgba(0,212,255,.35);box-shadow:0 0 0 3px rgba(0,212,255,.05)}
.note-ta::placeholder{color:var(--t3);font-family:var(--mono)}

/* ABOUT */
.ab-hero{background:var(--s1);border:1px solid var(--b1);border-radius:var(--r1);
